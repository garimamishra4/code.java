import java.util.*;
class RecursivePrint{
    public static void prrint(int n){
        if(n==1) 
        {
            System.out.println(n);
            return ; }
        prrint(n-1);
        System.out.println(n);
    }
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        System.out.println("enter n: ");
        int n = sc.nextInt();
        prrint(n);
    }
}
